  "tests": [
    {
      "name": "Like without auth",
      "method": "POST",
      "path": "/?action=like",
      "body": {"to_user_id": "00000000-0000-0000-0000-000000000000"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Incoming without auth",
      "method": "GET",
      "path": "/?action=incoming",
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "bot_run without key returns 403",
      "method": "POST",
      "path": "/?action=bot_run",
      "body": {},
      "expectedStatus": 403,
      "bodyMatcher": "partial"
    },
    {
      "name": "bot_run with correct key in body returns 200",
      "method": "POST",
      "path": "/?action=bot_run",
      "body": {"bot_key": "sparkladmin2024"},
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    }
  ]
